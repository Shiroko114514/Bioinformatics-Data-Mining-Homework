# Synthetic dataset (matches wam_splice_site.py / bayesian_network_splice.py)
# ─────────────────────────────────────────────────────────────

def _rand(weights: Dict[str, float]) -> str:
    r, cum = random.random(), 0.0
    for b, w in weights.items():
        cum += w
        if r < cum:
            return b
    return 'A'

def make_donor_positive(n: int = 500) -> List[str]:
    seqs = []
    for _ in range(n):
        p0 = _rand({'A': 0.35, 'G': 0.35, 'C': 0.15, 'T': 0.15})
        p1 = _rand({'A': 0.45, 'G': 0.35, 'C': 0.10, 'T': 0.10})
        p2 = ('G' if p0 in ('A', 'G') and random.random() < 0.70
              else _rand({'A': 0.20, 'G': 0.50, 'C': 0.15, 'T': 0.15}))
        p3, p4 = 'G', 'T'
        p5 = _rand({'A': 0.65, 'G': 0.15, 'C': 0.10, 'T': 0.10})
        p6 = _rand({'A': 0.70, 'G': 0.10, 'C': 0.10, 'T': 0.10})
        p7 = _rand({'A': 0.10, 'G': 0.65, 'C': 0.10, 'T': 0.15})
        p8 = ('T' if p5 == 'A' and random.random() < 0.75
              else _rand({'A': 0.10, 'G': 0.10, 'C': 0.10, 'T': 0.70}))
        seqs.append(''.join([p0, p1, p2, p3, p4, p5, p6, p7, p8]))
    return seqs

def make_donor_negative(n: int = 500) -> List[str]:
    seqs = []
    while len(seqs) < n:
        s = list(''.join(random.choices(list(BASES), k=9)))
        s[3], s[4] = 'G', 'T'
        seqs.append(''.join(s))
    return seqs


# ─────────────────────────────────────────────────────────────
# Evaluation helpers
# ─────────────────────────────────────────────────────────────

def evaluate_full(y_true: List[int], y_pred: List[int],
                  scores: Optional[List[float]] = None) -> Dict[str, float]:
    """Compute TP/FP/TN/FN + derived metrics. y labels: +1 / −1."""
    yt = np.array(y_true)
    yp = np.array(y_pred)
    tn, fp, fn, tp = confusion_matrix(yt, yp, labels=[-1, 1]).ravel()
    sens  = tp / (tp + fn) if (tp + fn) > 0 else 0.0
    spec  = tn / (tn + fp) if (tn + fp) > 0 else 0.0
    prec  = precision_score(yt, yp, pos_label=1, zero_division=0)
    f1    = f1_score(yt, yp, pos_label=1, zero_division=0)
    mcc   = matthews_corrcoef(yt, yp)
    auc   = roc_auc_score(yt, scores) if scores is not None else float('nan')
    return dict(TP=int(tp), FP=int(fp), TN=int(tn), FN=int(fn),
                sensitivity=float(sens), specificity=float(spec),
                precision=float(prec), F1=float(f1), MCC=float(mcc), AUC=float(auc))


# ─────────────────────────────────────────────────────────────
# Feature ablation study
# ─────────────────────────────────────────────────────────────

def ablation_study(train_pos: List[str], train_neg: List[str],
                   test_pos: List[str],   test_neg: List[str],
                   window: int = DONOR_WINDOW) -> None:
    """
    Compare different feature combinations with RBF-SVM.
    Shows which feature types contribute most to performance.
    """
    configs = [
        ('One-hot only',           ['one_hot']),
        ('k-mer (2+3)',            ['kmer2', 'kmer3']),
        ('Dinuc positional',       ['dinuc_pos']),
        ('PWM log-odds',           ['pwm']),
        ('One-hot + k-mer',        ['one_hot', 'kmer2', 'kmer3']),
        ('One-hot + dinuc + PWM',  ['one_hot', 'dinuc_pos', 'pwm']),
        ('Combined (all)',          list(FeatureExtractor.ALL_FEATURES)),
    ]

    test_seqs   = test_pos + test_neg
    test_labels = [1]*len(test_pos) + [-1]*len(test_neg)

    print("\n── Feature ablation (RBF-SVM, C=1.0) ────────────────────")
    print(f"{'Feature set':<30} {'Dim':>5} {'AUC-ROC':>9} {'MCC':>9} {'F1':>9}")
    print("─" * 66)

    for name, fts in configs:
        m = SVMSpliceSite(window=window, kernel='rbf', C=1.0, feature_set=fts)
        m.train(train_pos, train_neg)
        scores = m.decision_score_batch(test_seqs)
        preds  = [1 if s >= 0 else -1 for s in scores]
        met    = evaluate_full(test_labels, preds, scores)
        dim    = m.extractor.feature_dim
        print(f"  {name:<28} {dim:>5} {met['AUC']:>9.4f} {met['MCC']:>9.4f}"
              f" {met['F1']:>9.4f}")

    print("─" * 66)


# ─────────────────────────────────────────────────────────────
# Kernel comparison
# ─────────────────────────────────────────────────────────────

def kernel_comparison(train_pos: List[str], train_neg: List[str],
                      test_pos: List[str],  test_neg: List[str],
                      window: int = DONOR_WINDOW) -> None:
    """Compare linear / RBF / polynomial kernel SVMs."""
    kernels = [
        ('Linear',      dict(kernel='linear', C=1.0)),
        ('RBF C=0.1',   dict(kernel='rbf',    C=0.1,  gamma='scale')),
        ('RBF C=1.0',   dict(kernel='rbf',    C=1.0,  gamma='scale')),
        ('RBF C=10',    dict(kernel='rbf',    C=10.0, gamma='scale')),
        ('Poly d=2',    dict(kernel='poly',   C=1.0,  degree=2)),
        ('Poly d=3',    dict(kernel='poly',   C=1.0,  degree=3)),
    ]

    test_seqs   = test_pos + test_neg
    test_labels = [1]*len(test_pos) + [-1]*len(test_neg)

    print("\n── Kernel comparison (combined features) ─────────────────")
    print(f"{'Kernel / C':^18} {'Sens':>8} {'Spec':>8} {'AUC':>8} {'MCC':>8} {'F1':>8}")
    print("─" * 66)

    for name, kwargs in kernels:
        m = SVMSpliceSite(window=window,
                          feature_set=list(FeatureExtractor.ALL_FEATURES),
                          **kwargs)
        m.train(train_pos, train_neg)
        scores = m.decision_score_batch(test_seqs)
        preds  = [1 if s >= 0 else -1 for s in scores]
        met    = evaluate_full(test_labels, preds, scores)
        print(f"  {name:<16} {met['sensitivity']:>8.4f} {met['specificity']:>8.4f}"
              f" {met['AUC']:>8.4f} {met['MCC']:>8.4f} {met['F1']:>8.4f}")

    print("─" * 66)


# ─────────────────────────────────────────────────────────────
# Four-way comparison: WMM / WAM / BN / SVM
# ─────────────────────────────────────────────────────────────

def _build_probabilistic_models(train_pos, train_neg, window):
    """Build WMM and WAM baseline models (pure Python, no sklearn dep)."""

    class _PWM:
        def __init__(self, w):
            self.w = w; self.lo = None
        def train(self, pos, neg):
            n  = self.w
            bg = {b: 0.25 for b in BASES}
            ct = [{b: PSEUDOCOUNT for b in BASES} for _ in range(n)]
            for s in validate_seqs(pos, n):
                for i, c in enumerate(s):
                    ct[i][c] += 1
            self.lo = []
            for d in ct:
                tot = sum(d.values())
                self.lo.append({b: math.log(max(d[b]/tot, 1e-10)/bg[b]) for b in BASES})
        def score(self, seq):
            return sum(self.lo[i].get(c, 0) for i, c in enumerate(seq.upper()) if c in BASE_IDX)
        def score_batch(self, seqs):
            return [self.score(s) for s in seqs]

    class _WAM:
        def __init__(self, w):
            self.w = w; self.first = None; self.cpt = None
        def train(self, pos, neg):
            valid = validate_seqs(pos, self.w)
            bg    = {b: 0.25 for b in BASES}
            fc = {b: PSEUDOCOUNT for b in BASES}
            for s in valid: fc[s[0]] += 1
            tot = sum(fc.values())
            self.first = {b: fc[b]/tot for b in BASES}
            cond = [{p: {c: PSEUDOCOUNT for c in BASES} for p in BASES}
                    for _ in range(self.w)]
            for s in valid:
                for i in range(1, self.w):
                    cond[i][s[i-1]][s[i]] += 1
            self.cpt = []
            for i, d in enumerate(cond):
                row = {}
                for p in BASES:
                    t = sum(d[p].values())
                    row[p] = {c: d[p][c]/t for c in BASES}
                self.cpt.append(row)
        def score(self, seq):
            seq = seq.upper()
            s   = math.log(max(self.first.get(seq[0], 1e-10), 1e-10) / 0.25)
            for i in range(1, self.w):
                p = self.cpt[i][seq[i-1]][seq[i]]
                s += math.log(max(p, 1e-10) / 0.25)
            return s
        def score_batch(self, seqs):
            return [self.score(s) for s in seqs]

    wmm = _PWM(window);  wmm.train(train_pos, train_neg)
    wam = _WAM(window);  wam.train(train_pos, train_neg)
    return wmm, wam


def four_way_comparison(train_pos: List[str], train_neg: List[str],
                        test_pos: List[str],  test_neg: List[str],
                        window: int = DONOR_WINDOW) -> None:
    """Full comparison: WMM, WAM, BN Chow-Liu, SVM (RBF, combined features)."""

    test_seqs   = test_pos + test_neg
    test_labels_pm1 = [1]*len(test_pos) + [-1]*len(test_neg)   # ±1 for SVM
    test_labels_01  = [1]*len(test_pos) + [0]*len(test_neg)    # 0/1 for BN

    wmm, wam = _build_probabilistic_models(train_pos, train_neg, window)

    # Try to import BN model from companion file
    bn_scores = None
    try:
        import sys, os
        sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
        from bayesian_network_splice import BayesianNetworkModel, validate_seqs as bn_val
        bn = BayesianNetworkModel(window=window, site='donor', structure='chow-liu')
        bn.train(train_pos, train_neg)
        bn_scores = bn.score_batch(test_seqs)
    except ImportError:
        pass

    svm = SVMSpliceSite(window=window, kernel='rbf', C=1.0,
                         feature_set=list(FeatureExtractor.ALL_FEATURES))
    svm.train(train_pos, train_neg)

    wmm_sc  = wmm.score_batch(test_seqs)
    wam_sc  = wam.score_batch(test_seqs)
    svm_sc  = svm.decision_score_batch(test_seqs)

    models = [
        ('WMM',          wmm_sc,  test_labels_pm1),
        ('WAM',          wam_sc,  test_labels_pm1),
    ]
    if bn_scores is not None:
        models.append(('BN Chow-Liu', bn_scores, test_labels_pm1))
    models.append(('SVM (RBF)', svm_sc, test_labels_pm1))

    print("\n" + "=" * 68)
    print("  Four-way comparison — Donor Site Prediction")
    print("=" * 68)
    print(f"  {'Metric':<16}", end="")
    for name, _, _ in models:
        print(f"{name:>14}", end="")
    print()
    print("  " + "─" * 64)

    rows = [
        ('Sensitivity', 'sensitivity'),
        ('Specificity', 'specificity'),
        ('Precision',   'precision'),
        ('F1 score',    'F1'),
        ('MCC',         'MCC'),
        ('AUC-ROC',     'AUC'),
    ]

    all_mets = []
    for _, sc, lbl in models:
        threshold = 0.0
        preds = [1 if s >= threshold else -1 for s in sc]
        all_mets.append(evaluate_full(lbl, preds, sc))

    for label, key in rows:
        vals = [m[key] for m in all_mets]
        best = max(vals)
        print(f"  {label:<16}", end="")
        for v in vals:
            mark = "◀" if abs(v - best) < 1e-6 else " "
            print(f"{v:>13.4f}{mark}", end="")
        print()

    print("  " + "─" * 64)
    print("  ◀ = best in row")
    print("=" * 68)


