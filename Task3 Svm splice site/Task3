"""
SVM-based splice site prediction for eukaryotic genes
======================================================
References:
  Zien et al. (2000)   – Engineering support vector machine kernels that
                          recognize translation initiation sites. Bioinformatics.
  Sonnenburg et al.    – Large scale training of SVMs with application to
                          splice site prediction. JMLR (2006).
  Vapnik (1995)        – The Nature of Statistical Learning Theory.

Key ideas vs. probabilistic models (WMM / WAM / BN)
----------------------------------------------------
  WMM / WAM / BN : generative models  — P(x | class)
  SVM            : discriminative model — maximises P(class | x) margin

SVM discriminant:
  f(x) = sign( Σᵢ αᵢ yᵢ K(xᵢ, x) + b )

  Linear  kernel: K(x,x') = x·x'                     → interpretable weight vector
  RBF     kernel: K(x,x') = exp(−γ ‖x−x'‖²)          → best for nonlinear boundaries
  Poly    kernel: K(x,x') = (x·x' + 1)^d              → captures interaction terms

Feature representations
-----------------------
  one_hot       : L × 4 binary indicator matrix (flattened)  → 36 dims for 9-bp window
  kmer          : counts of all k-mers in window (k=2 → 16, k=3 → 64)
  pwm_score     : per-position WMM log-odds (L dims)
  dinucleotide  : position-specific dinucleotide one-hot ((L-1)×16 dims)
  combined      : concatenation of any subset above

Usage
-----
>>> from svm_splice_site import SVMSpliceSite, FeatureExtractor, demo
>>> fe   = FeatureExtractor(window=9, features=['one_hot', 'kmer2', 'kmer3'])
>>> svm  = SVMSpliceSite(window=9, kernel='rbf', feature_set=['one_hot','kmer2','kmer3'])
>>> svm.train(pos_seqs, neg_seqs)
>>> score = svm.decision_score('CAGGTAAGT')
>>> svm.print_summary()
>>> demo()
"""

import math
import random
import itertools
from typing import List, Dict, Tuple, Optional, Union

import numpy as np
from sklearn.svm import SVC
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import StratifiedKFold, cross_val_score
from sklearn.pipeline import Pipeline
from sklearn.metrics import (matthews_corrcoef, roc_auc_score,
                              precision_score, recall_score, f1_score,
                              confusion_matrix)

# ─────────────────────────────────────────────────────────────
# Constants
# ─────────────────────────────────────────────────────────────

BASES          = ('A', 'C', 'G', 'T')
BASE_IDX       = {b: i for i, b in enumerate(BASES)}
PSEUDOCOUNT    = 0.5
DONOR_WINDOW   = 9    # exon[-3,-2,-1] | intron[+1..+6]
ACCEPTOR_WINDOW = 23  # intron[-20..-1] | exon[+1..+3]
DONOR_GT_POS   = 3    # 0-indexed start of GT in 9-bp window
ACCEPTOR_AG_POS = 20  # 0-indexed start of AG in 23-bp window

# ─────────────────────────────────────────────────────────────
# Sequence utilities
# ─────────────────────────────────────────────────────────────

def validate_seqs(seqs: List[str], window: int) -> List[str]:
    out = []
    for s in seqs:
        s = s.upper().strip()
        if len(s) == window and all(c in BASE_IDX for c in s):
            out.append(s)
    return out


# ─────────────────────────────────────────────────────────────
# Feature extraction
# ─────────────────────────────────────────────────────────────

class FeatureExtractor:
    """
    Transform raw nucleotide windows into numeric feature vectors.

    Supported feature types
    -----------------------
    'one_hot'     : flattened one-hot, shape (4L,)
    'kmer2'       : dinucleotide frequencies, shape (16,)
    'kmer3'       : trinucleotide frequencies, shape (64,)
    'dinuc_pos'   : position-specific dinucleotide one-hot, shape (16*(L-1),)
    'pwm'         : per-position WMM log-odds trained on pos set, shape (L,)
    'combined'    : concatenation of all of the above
    """

    ALL_FEATURES = ('one_hot', 'kmer2', 'kmer3', 'dinuc_pos', 'pwm')

    def __init__(self, window: int,
                 features: Union[str, List[str]] = 'combined') -> None:
        self.window = window
        if features == 'combined':
            self.features = list(self.ALL_FEATURES)
        elif isinstance(features, str):
            self.features = [features]
        else:
            self.features = list(features)

        self._kmers2 = [''.join(p) for p in itertools.product(BASES, repeat=2)]
        self._kmers3 = [''.join(p) for p in itertools.product(BASES, repeat=3)]
        self._kmer2_idx = {k: i for i, k in enumerate(self._kmers2)}
        self._kmer3_idx = {k: i for i, k in enumerate(self._kmers3)}

        self._pwm_lo: Optional[List[Dict[str, float]]] = None  # set by fit()

    # ── Fit (for PWM feature) ─────────────────────────────────

    def fit(self, pos_seqs: List[str]) -> 'FeatureExtractor':
        """
        Estimate foreground PWM from positive sequences.
        Must be called before extracting 'pwm' features.
        """
        n = self.window
        counts = [{b: PSEUDOCOUNT for b in BASES} for _ in range(n)]
        for seq in pos_seqs:
            for i, c in enumerate(seq[:n]):
                if c in BASE_IDX:
                    counts[i][c] += 1
        bg = {b: 0.25 for b in BASES}
        self._pwm_lo = []
        for pos_ct in counts:
            total = sum(pos_ct.values())
            self._pwm_lo.append(
                {b: math.log(max(pos_ct[b] / total, 1e-10) / bg[b])
                 for b in BASES}
            )
        return self

    # ── Individual feature functions ──────────────────────────

    def _one_hot(self, seq: str) -> np.ndarray:
        """Shape: (4 * window,)"""
        vec = np.zeros(4 * self.window, dtype=np.float32)
        for i, c in enumerate(seq):
            if c in BASE_IDX:
                vec[i * 4 + BASE_IDX[c]] = 1.0
        return vec

    def _kmer_freq(self, seq: str, k: int) -> np.ndarray:
        """Normalised k-mer frequency vector, shape (4^k,)."""
        idx_map = self._kmer2_idx if k == 2 else self._kmer3_idx
        n_kmers = len(idx_map)
        vec = np.zeros(n_kmers, dtype=np.float32)
        count = 0
        for i in range(len(seq) - k + 1):
            km = seq[i:i+k]
            if km in idx_map:
                vec[idx_map[km]] += 1
                count += 1
        if count > 0:
            vec /= count
        return vec

    def _dinuc_pos(self, seq: str) -> np.ndarray:
        """
        Position-specific dinucleotide one-hot.
        Shape: ((window-1) * 16,)
        Captures the same first-order info as WAM but as binary features.
        """
        size = (self.window - 1) * 16
        vec  = np.zeros(size, dtype=np.float32)
        for i in range(self.window - 1):
            a, b = seq[i], seq[i + 1]
            if a in BASE_IDX and b in BASE_IDX:
                di_idx = BASE_IDX[a] * 4 + BASE_IDX[b]
                vec[i * 16 + di_idx] = 1.0
        return vec

    def _pwm_scores(self, seq: str) -> np.ndarray:
        """Per-position log-odds score vector, shape (window,)."""
        if self._pwm_lo is None:
            raise RuntimeError("Call fit() before extracting 'pwm' features.")
        vec = np.zeros(self.window, dtype=np.float32)
        for i, c in enumerate(seq[:self.window]):
            if c in BASE_IDX:
                vec[i] = float(self._pwm_lo[i].get(c, 0.0))
        return vec

    # ── Public transform ─────────────────────────────────────

    def transform_one(self, seq: str) -> np.ndarray:
        """Return feature vector for a single sequence string."""
        parts = []
        for ft in self.features:
            if ft == 'one_hot':
                parts.append(self._one_hot(seq))
            elif ft == 'kmer2':
                parts.append(self._kmer_freq(seq, 2))
            elif ft == 'kmer3':
                parts.append(self._kmer_freq(seq, 3))
            elif ft == 'dinuc_pos':
                parts.append(self._dinuc_pos(seq))
            elif ft == 'pwm':
                parts.append(self._pwm_scores(seq))
            else:
                raise ValueError(f"Unknown feature type: {ft!r}")
        return np.concatenate(parts)

    def transform(self, seqs: List[str]) -> np.ndarray:
        """Return feature matrix, shape (N, d)."""
        return np.stack([self.transform_one(s) for s in seqs])

    @property
    def feature_dim(self) -> int:
        """Total feature dimension."""
        dim = 0
        for ft in self.features:
            if ft == 'one_hot':    dim += 4 * self.window
            elif ft == 'kmer2':    dim += 16
            elif ft == 'kmer3':    dim += 64
            elif ft == 'dinuc_pos': dim += 16 * (self.window - 1)
            elif ft == 'pwm':      dim += self.window
        return dim

    def feature_names(self) -> List[str]:
        """Human-readable name for each feature dimension."""
        names = []
        for ft in self.features:
            if ft == 'one_hot':
                for i in range(self.window):
                    for b in BASES:
                        names.append(f'oh_pos{i}_{b}')
            elif ft == 'kmer2':
                names += [f'k2_{k}' for k in self._kmers2]
            elif ft == 'kmer3':
                names += [f'k3_{k}' for k in self._kmers3]
            elif ft == 'dinuc_pos':
                for i in range(self.window - 1):
                    for a in BASES:
                        for b in BASES:
                            names.append(f'dn_pos{i}_{a}{b}')
            elif ft == 'pwm':
                names += [f'pwm_pos{i}' for i in range(self.window)]
        return names


# ─────────────────────────────────────────────────────────────
# SVM model
# ─────────────────────────────────────────────────────────────

class SVMSpliceSite:
    """
    SVM splice site predictor.

    Parameters
    ----------
    window      : sequence window length
    site        : 'donor' or 'acceptor'
    kernel      : 'linear', 'rbf', 'poly', 'sigmoid'
    feature_set : list of feature types (see FeatureExtractor)
    C           : SVM regularisation (slack penalty)
    gamma       : RBF/poly kernel width; 'scale' = 1/(n_features × X.var())
    degree      : polynomial kernel degree
    probability : if True, enable Platt scaling for probability estimates
    """

    def __init__(self,
                 window: int = DONOR_WINDOW,
                 site: str = 'donor',
                 kernel: str = 'rbf',
                 feature_set: Union[str, List[str]] = 'combined',
                 C: float = 1.0,
                 gamma: Union[str, float] = 'scale',
                 degree: int = 3,
                 probability: bool = True) -> None:
        self.window      = window
        self.site        = site
        self.kernel      = kernel
        self.feature_set = feature_set
        self.C           = C
        self.gamma       = gamma
        self.degree      = degree
        self.probability = probability

        self.extractor: Optional[FeatureExtractor] = None
        self.pipeline:  Optional[Pipeline]         = None
        self._train_pos: Optional[List[str]]       = None
        self._train_neg: Optional[List[str]]       = None

    # ── Training ─────────────────────────────────────────────

    def train(self, pos_seqs: List[str], neg_seqs: List[str]) -> 'SVMSpliceSite':
        """
        Fit the SVM on positive (true splice sites) and negative sequences.

        Internally builds:
          FeatureExtractor (fit on pos) → StandardScaler → SVC
        """
        pos = validate_seqs(pos_seqs, self.window)
        neg = validate_seqs(neg_seqs, self.window)
        if not pos:
            raise ValueError("No valid positive sequences after filtering.")
        self._train_pos = pos
        self._train_neg = neg

        self.extractor = FeatureExtractor(self.window, self.feature_set)
        self.extractor.fit(pos)

        X_pos = self.extractor.transform(pos)
        X_neg = self.extractor.transform(neg)
        X     = np.vstack([X_pos, X_neg])
        y     = np.array([1]*len(pos) + [-1]*len(neg), dtype=int)

        svc = SVC(kernel=self.kernel, C=self.C, gamma=self.gamma,
                  degree=self.degree, probability=self.probability,
                  class_weight='balanced', random_state=42)

        self.pipeline = Pipeline([
            ('scaler', StandardScaler()),
            ('svm',    svc),
        ])
        self.pipeline.fit(X, y)
        return self

    # ── Scoring ───────────────────────────────────────────────

    def _extract(self, seqs: Union[str, List[str]]) -> np.ndarray:
        if isinstance(seqs, str):
            seqs = [seqs]
        seqs = [s.upper() for s in seqs]
        return self.extractor.transform(seqs)

    def decision_score(self, seq: str) -> float:
        """
        Return the signed distance to the decision hyperplane.
        Positive → predicted splice site; negative → predicted non-site.
        """
        if self.pipeline is None:
            raise RuntimeError("Call train() first.")
        X = self._extract(seq)
        return float(self.pipeline.decision_function(X)[0])

    def decision_score_batch(self, seqs: List[str]) -> List[float]:
        if self.pipeline is None:
            raise RuntimeError("Call train() first.")
        X = self._extract(seqs)
        return self.pipeline.decision_function(X).tolist()

    def predict(self, seq: str, threshold: float = 0.0) -> int:
        """Return +1 / −1."""
        return int(self.decision_score(seq) >= threshold)

    def predict_batch(self, seqs: List[str],
                      threshold: float = 0.0) -> List[int]:
        return [self.predict(s, threshold) for s in seqs]

    def predict_proba(self, seq: str) -> float:
        """P(splice site | seq) via Platt scaling (requires probability=True)."""
        if not self.probability:
            raise RuntimeError("Set probability=True at construction.")
        X = self._extract(seq)
        return float(self.pipeline.predict_proba(X)[0, 1])

    # ── Cross-validation ──────────────────────────────────────

    def cross_validate(self, pos_seqs: List[str], neg_seqs: List[str],
                       n_folds: int = 5) -> Dict[str, float]:
        """
        Stratified k-fold CV on the combined dataset.
        Returns mean ± std for AUC-ROC and MCC.
        """
        pos = validate_seqs(pos_seqs, self.window)
        neg = validate_seqs(neg_seqs, self.window)

        extractor = FeatureExtractor(self.window, self.feature_set).fit(pos)
        X = np.vstack([extractor.transform(pos), extractor.transform(neg)])
        y = np.array([1]*len(pos) + [-1]*len(neg), dtype=int)

        svc = SVC(kernel=self.kernel, C=self.C, gamma=self.gamma,
                  degree=self.degree, probability=True,
                  class_weight='balanced', random_state=42)
        pipe = Pipeline([('scaler', StandardScaler()), ('svm', svc)])

        cv = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=42)

        auc_scores = cross_val_score(pipe, X, y, cv=cv, scoring='roc_auc')
        mcc_scores = cross_val_score(pipe, X, y, cv=cv, scoring='matthews_corrcoef')
        f1_scores  = cross_val_score(pipe, X, y, cv=cv, scoring='f1')

        return {
            'auc_mean': float(auc_scores.mean()),
            'auc_std':  float(auc_scores.std()),
            'mcc_mean': float(mcc_scores.mean()),
            'mcc_std':  float(mcc_scores.std()),
            'f1_mean':  float(f1_scores.mean()),
            'f1_std':   float(f1_scores.std()),
        }

    # ── Feature importance (linear kernel only) ───────────────

    def top_features(self, n: int = 15) -> List[Tuple[str, float]]:
        """
        Return the top-n most discriminative features by |weight|.
        Only meaningful for linear kernel.
        """
        if self.pipeline is None:
            raise RuntimeError("Call train() first.")
        if self.kernel != 'linear':
            raise ValueError("Feature weights are only interpretable for linear kernel.")
        svm     = self.pipeline.named_steps['svm']
        weights = svm.coef_[0]                   # shape (d,)
        names   = self.extractor.feature_names()
        ranked  = sorted(zip(names, weights.tolist()),
                         key=lambda x: abs(x[1]), reverse=True)
        return ranked[:n]

    # ── Genome scanner ────────────────────────────────────────

    def scan(self, genome: str, threshold: float = 0.0
             ) -> List[Tuple[int, float]]:
        """
        Slide the SVM over a genome string.
        Returns (canonical_dinucleotide_position, decision_score) for hits.
        """
        genome  = genome.upper()
        w       = self.window
        dinuc   = 'GT' if self.site == 'donor' else 'AG'
        off     = DONOR_GT_POS if self.site == 'donor' else ACCEPTOR_AG_POS
        hits: List[Tuple[int, float]] = []
        for i in range(off, len(genome) - w + off + 1):
            win = genome[i - off: i - off + w]
            if len(win) != w:
                continue
            if win[off: off + 2] != dinuc:
                continue
            sc = self.decision_score(win)
            if sc >= threshold:
                hits.append((i, sc))
        return hits

    # ── Summary ───────────────────────────────────────────────

    def print_summary(self) -> None:
        if self.pipeline is None:
            print("Not trained.")
            return
        svm = self.pipeline.named_steps['svm']
        n_sv = svm.n_support_.sum()
        dim  = self.extractor.feature_dim

        print(f"\nSVM Splice Site Predictor — {self.site} site")
        print("=" * 52)
        print(f"  Window      : {self.window} bp")
        print(f"  Kernel      : {self.kernel}")
        print(f"  C           : {self.C}")
        print(f"  Gamma       : {self.gamma}")
        print(f"  Features    : {', '.join(self.extractor.features)}")
        print(f"  Feature dim : {dim}")
        print(f"  Support vecs: {n_sv}")
        if self.kernel == 'linear':
            svm_weights = svm.coef_[0]
            print(f"  ‖w‖₂        : {float(np.linalg.norm(svm_weights)):.4f}")
            print(f"  Margin width: {2.0 / float(np.linalg.norm(svm_weights)):.4f}")
        print("=" * 52)


